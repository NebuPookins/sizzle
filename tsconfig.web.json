{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "out"
  },
  "include": ["src/renderer/**/*", "src/shared/**/*", "src/preload/**/*"]
}
