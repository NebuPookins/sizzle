{
  "name": "sizzle",
  "version": "0.1.0",
  "private": true,
  "description": "IDE-style Tauri app for browsing local projects and launching AI coding agents in project-rooted terminals.",
  "author": "Nebu Pookins <nebupookins@gmail.com>",
  "keywords": [
    "tauri",
    "react",
    "typescript",
    "desktop",
    "developer-tools",
    "project-launcher",
    "terminal",
    "ai-agents",
    "claude-code",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NebuPookins/sizzle.git"
  },
  "homepage": "https://github.com/NebuPookins/sizzle#readme",
  "bugs": {
    "url": "https://github.com/NebuPookins/sizzle/issues"
  },
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "tauri dev --no-watch",
    "build": "tauri build",
    "dev:renderer": "vite",
    "build:renderer": "node scripts/check-invoke.cjs && vite build",
    "preview": "vite preview",
    "check:invoke": "node scripts/check-invoke.cjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-code-block-lowlight": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-task-item": "^3.22.5",
    "@tiptap/extension-task-list": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "highlight.js": "^11.0.0",
    "lowlight": "^3.3.0",
    "marked": "^18.0.3",
    "prosemirror-markdown": "^1.13.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
